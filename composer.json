{
    "name": "ailuracode/bladcn",
    "version": "1.0.0",
    "description": "CLI to add shadcn-style Blade components to Laravel projects",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "AiluraCode"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "symfony/console": "^7.0|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.4",
        "laravel/pint": "^1.29",
        "larastan/larastan": "^3.10",
        "driftingly/rector-laravel": "^2.5",
        "laravel/framework": "^12.0",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "AiluraCode\\Bladcn\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AiluraCode\\Bladcn\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/bladcn"
    ],
    "scripts": {
        "lint": [
            "rector",
            "pint --parallel"
        ],
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run"
        ],
        "test:types": "@phpstan",
        "test:unit": "phpunit",
        "test": [
            "@test:unit",
            "@test:lint",
            "@test:types"
        ],
        "ci": "@test",
        "phpstan": "phpstan analyse -c phpstan.neon.dist --memory-limit=512M",
        "rector": "rector process",
        "rector:check": "rector process --dry-run",
        "pint": "pint",
        "pint:check": "pint --parallel --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "AiluraCode\\Bladcn\\Laravel\\BladcnCliServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}